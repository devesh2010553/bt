<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Partner Revenue – Brajwasi Admin</title>
<link rel="icon" href="/images/favicon.png">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
:root{--gold:#B8780A;--gold-l:#D4920E;--gold-d:#8A5A06;--gold-bg:#FFF8EC;--bg:#fff;--bg2:#F8F5F0;--border:#E8DDD0;--text:#1A1208;--muted:#7A6A55;--light:#A0917E;--green:#1A7A3A;--green-bg:#EAF7EE;--red:#C0392B;--red-bg:#FDEDEB;--blue:#1A5DAB;--blue-bg:#EEF4FF;}
*{box-sizing:border-box;margin:0;padding:0;}body{font-family:'DM Sans',sans-serif;background:var(--bg2);color:var(--text);}
.sidebar{position:fixed;left:0;top:0;bottom:0;width:220px;background:var(--bg);border-right:1px solid var(--border);display:flex;flex-direction:column;z-index:100;}
.sidebar-brand{padding:16px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;}
.brand-icon{width:36px;height:36px;background:linear-gradient(135deg,var(--gold-l),var(--gold-d));border-radius:8px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:14px;}
.brand-name h1{font-family:'Playfair Display',serif;font-size:13px;}.brand-name span{font-size:9px;color:var(--gold);letter-spacing:1.5px;text-transform:uppercase;}
.nav-body{padding:8px;flex:1;overflow-y:auto;}
.nav-item{display:flex;align-items:center;gap:9px;padding:9px 14px;color:var(--muted);text-decoration:none;font-size:13px;font-weight:500;border-radius:8px;margin:1px 0;transition:all .2s;}
.nav-item:hover{color:var(--gold-d);background:var(--gold-bg);}
.nav-item.active{color:var(--gold-d);background:var(--gold-bg);font-weight:700;}
.nav-item i{width:16px;font-size:12px;}
.sidebar-footer{padding:10px;border-top:1px solid var(--border);}
.main{margin-left:220px;min-height:100vh;}
.topbar{background:var(--bg);border-bottom:1px solid var(--border);padding:13px 24px;display:flex;justify-content:space-between;align-items:center;}
.topbar h2{font-size:18px;font-weight:700;}
.content{padding:22px;}
/* Summary cards */
.summary-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:16px;margin-bottom:24px;}
.sum-card{background:var(--bg);border:1px solid var(--border);border-radius:12px;padding:16px 18px;}
.sum-card .lbl{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px;}
.sum-card .val{font-size:22px;font-weight:800;}
/* Partner cards */
.partner-card{background:var(--bg);border:1px solid var(--border);border-radius:14px;margin-bottom:20px;overflow:hidden;}
.partner-head{padding:16px 20px;background:var(--gold-bg);border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;}
.partner-name{font-size:16px;font-weight:700;}
.partner-sub{font-size:12px;color:var(--muted);margin-top:2px;}
.stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--border);}
.stat-cell{background:var(--bg);padding:14px 16px;text-align:center;}
.stat-cell .lbl{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px;}
.stat-cell .val{font-size:18px;font-weight:800;}
.trips-table{width:100%;border-collapse:collapse;font-size:13px;}
.trips-table th{padding:10px 14px;text-align:left;background:var(--bg2);font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);border-bottom:1px solid var(--border);}
.trips-table td{padding:10px 14px;border-bottom:1px solid var(--border);}
.trips-table tr:last-child td{border-bottom:none;}
.trips-table tr:hover td{background:var(--bg2);}
.badge{display:inline-block;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;}
.badge-green{background:var(--green-bg);color:var(--green);}
.badge-gold{background:var(--gold-bg);color:var(--gold-d);}
.empty{text-align:center;padding:30px;color:var(--light);font-size:14px;}
.btn{display:inline-flex;align-items:center;gap:6px;padding:7px 14px;border-radius:8px;font-size:12px;font-weight:700;cursor:pointer;border:none;font-family:inherit;text-decoration:none;}
.btn-secondary{background:var(--bg2);color:var(--muted);border:1px solid var(--border);}
.collapsible{display:none;}
.collapsible.open{display:block;}
@media(max-width:768px){.sidebar{display:none}.main{margin-left:0}.stats-row{grid-template-columns:repeat(2,1fr)}}
</style>
</head>
<body>
<aside class="sidebar">
  <div class="sidebar-brand">
    <div class="brand-icon"><i class="fas fa-car"></i></div>
    <div class="brand-name"><h1>Brajwasi Admin</h1><span>Panel</span></div>
  </div>
  <div class="nav-body">
    <a href="/admin" class="nav-item"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
    <a href="/admin/bookings" class="nav-item"><i class="fas fa-calendar-check"></i> Bookings</a>
    <a href="/admin/partners" class="nav-item"><i class="fas fa-handshake"></i> Partners</a>
    <a href="/admin/partner-revenue" class="nav-item active"><i class="fas fa-chart-bar"></i> Partner Revenue</a>
    <a href="/admin/testimonials" class="nav-item"><i class="fas fa-star"></i> Reviews</a>
  </div>
  <div class="sidebar-footer">
    <a href="/" target="_blank" class="nav-item"><i class="fas fa-external-link-alt"></i> View Website</a>
    <a href="/admin/logout" class="nav-item" style="color:var(--red)"><i class="fas fa-sign-out-alt"></i> Logout</a>
  </div>
</aside>

<main class="main">
  <div class="topbar">
    <h2><i class="fas fa-chart-bar" style="color:var(--gold);margin-right:8px"></i>Partner Revenue</h2>
    <a href="/admin" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Dashboard</a>
  </div>

  <div class="content">
    <%
      var totalGross = partnerStats.reduce(function(s,p){return s+p.grossRevenue;},0);
      var totalComm  = partnerStats.reduce(function(s,p){return s+p.commission;},0);
      var totalNet   = partnerStats.reduce(function(s,p){return s+p.netEarning;},0);
      var totalTrips = partnerStats.reduce(function(s,p){return s+p.tripCount;},0);
    %>
    <!-- Summary -->
    <div class="summary-grid">
      <div class="sum-card" style="border-left:3px solid var(--blue)">
        <div class="lbl">Total Partners</div>
        <div class="val" style="color:var(--blue)"><%= partnerStats.length %></div>
      </div>
      <div class="sum-card" style="border-left:3px solid var(--gold)">
        <div class="lbl">Total Trips (Completed)</div>
        <div class="val" style="color:var(--gold-d)"><%= totalTrips %></div>
      </div>
      <div class="sum-card" style="border-left:3px solid var(--text)">
        <div class="lbl">Total Gross Revenue</div>
        <div class="val">₹<%= totalGross.toLocaleString('en-IN') %></div>
      </div>
      <div class="sum-card" style="border-left:3px solid var(--gold)">
        <div class="lbl">Admin Commission (10%)</div>
        <div class="val" style="color:var(--gold-d)">₹<%= totalComm.toLocaleString('en-IN') %></div>
      </div>
      <div class="sum-card" style="border-left:3px solid var(--green)">
        <div class="lbl">Total Partner Payouts</div>
        <div class="val" style="color:var(--green)">₹<%= totalNet.toLocaleString('en-IN') %></div>
      </div>
    </div>

    <% if(!partnerStats.length){ %>
    <div class="empty"><i class="fas fa-users" style="font-size:32px;display:block;margin-bottom:10px;color:var(--border)"></i>No approved partners yet.</div>
    <% } else { partnerStats.forEach(function(p, pi){ %>
    <div class="partner-card">
      <div class="partner-head">
        <div>
          <div class="partner-name"><%= p.ownerName %> &nbsp;<span style="font-size:12px;color:var(--muted);font-weight:400"><%= p.carModel %> · <%= p.carNumber %></span></div>
          <div class="partner-sub"><i class="fas fa-phone" style="margin-right:4px"></i><%= p.phone %> &nbsp;·&nbsp; <i class="fas fa-envelope" style="margin-right:4px"></i><%= p.email %></div>
        </div>
        <button onclick="toggleTrips('<%= p._id %>')" style="background:var(--bg);border:1px solid var(--border);color:var(--muted);padding:6px 14px;border-radius:8px;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit">
          <i class="fas fa-list" style="margin-right:5px"></i>View Trips (<%= p.tripCount %>)
        </button>
      </div>

      <div class="stats-row">
        <div class="stat-cell">
          <div class="lbl">Trips Done</div>
          <div class="val" style="color:var(--blue)"><%= p.tripCount %></div>
        </div>
        <div class="stat-cell">
          <div class="lbl">Gross Revenue</div>
          <div class="val">₹<%= p.grossRevenue.toLocaleString('en-IN') %></div>
        </div>
        <div class="stat-cell">
          <div class="lbl">Commission (<%= p.commissionPct %>%)</div>
          <div class="val" style="color:var(--red)">₹<%= p.commission.toLocaleString('en-IN') %></div>
        </div>
        <div class="stat-cell">
          <div class="lbl">Net Earning</div>
          <div class="val" style="color:var(--green)">₹<%= p.netEarning.toLocaleString('en-IN') %></div>
        </div>
      </div>

      <!-- Trip list (collapsible) -->
      <div id="trips-<%= p._id %>" class="collapsible">
        <% if(!p.bookings.length){ %>
        <div class="empty">No completed trips yet.</div>
        <% } else { %>
        <div style="overflow-x:auto">
          <table class="trips-table">
            <thead>
              <tr>
                <th>Booking ID</th>
                <th>Customer</th>
                <th>Route</th>
                <th>Date</th>
                <th>Actual KM</th>
                <th>Toll</th>
                <th>Base Fare</th>
                <th>Commission</th>
                <th>Partner Earns</th>
              </tr>
            </thead>
            <tbody>
              <% p.bookings.forEach(function(b){ 
                var gross = (b.finalFare||0)+(b.tollAmount||0);
                var comm  = Math.round(gross*(p.commissionPct||10)/100);
                var net   = gross-comm;
              %>
              <tr>
                <td><span class="badge badge-gold"><%= b.bookingId %></span></td>
                <td><%= b.customerName %><br><span style="color:var(--muted);font-size:11px"><%= b.customerPhone %></span></td>
                <td style="font-size:12px"><%= b.pickupLocation %> → <%= b.dropLocation %></td>
                <td style="font-size:12px"><%= new Date(b.journeyDate).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) %></td>
                <td><%= b.actualKm||'—' %> km</td>
                <td>₹<%= (b.tollAmount||0).toLocaleString('en-IN') %></td>
                <td>₹<%= (b.finalFare||0).toLocaleString('en-IN') %></td>
                <td style="color:var(--red)">− ₹<%= comm.toLocaleString('en-IN') %></td>
                <td><strong style="color:var(--green)">₹<%= net.toLocaleString('en-IN') %></strong></td>
              </tr>
              <% }); %>
            </tbody>
            <tfoot>
              <tr style="background:var(--bg2)">
                <td colspan="6" style="padding:10px 14px;font-weight:700">Totals</td>
                <td style="padding:10px 14px;font-weight:700">₹<%= p.bookings.reduce(function(s,b){return s+(b.finalFare||0);},0).toLocaleString('en-IN') %></td>
                <td style="padding:10px 14px;color:var(--red);font-weight:700">− ₹<%= p.commission.toLocaleString('en-IN') %></td>
                <td style="padding:10px 14px;color:var(--green);font-weight:800;font-size:15px">₹<%= p.netEarning.toLocaleString('en-IN') %></td>
              </tr>
            </tfoot>
          </table>
        </div>
        <% } %>
      </div>
    </div>
    <% }); } %>
  </div>
</main>

<script>
function toggleTrips(id) {
  var el = document.getElementById('trips-' + id);
  if (el) el.classList.toggle('open');
}
</script>
</body>
</html>
